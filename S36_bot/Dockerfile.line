FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends tzdata libzbar0 fonts-dejavu-core && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir flask line-bot-sdk pillow qrcode[pil]

COPY tools_agent.py session_state.py .
COPY S36_bot/line_bot.py .
COPY promptpay_logo.jpg Thai_QR_Payment_Logo.png Mitr-Regular.ttf ./

ENV TZ=Asia/Bangkok

EXPOSE 5000

CMD ["python", "line_bot.py"]
